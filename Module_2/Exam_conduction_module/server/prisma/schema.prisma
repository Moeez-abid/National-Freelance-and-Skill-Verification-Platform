generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================================================
// ENUMS
// ===================================================================

enum UserRole {
  freelancer
  client
  admin
  moderator
  @@map("user_role")
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  expert
  @@map("skill_level")
}

enum VerificationStatus {
  pending
  in_review
  verified
  rejected
  expired
  @@map("verification_status")
}

// ===================================================================
// MODULE 1: SHARED TABLES (Required for Foreign Keys)
// ===================================================================

model User {
  id                Int      @id @default(autoincrement())
  uuid              String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String   @unique @db.VarChar(150)
  password_hash     String   @db.VarChar(255)
  first_name        String   @db.VarChar(50)
  last_name         String   @db.VarChar(50)
  role              UserRole @default(freelancer)
  created_at        DateTime @default(now())
  
  test_attempts     EcTestAttempt[]
  certificates      EcCertificate[]
  badges            EcBadge[]

  @@map("users")
}

model Skill {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skill_name  String   @unique @db.VarChar(100)
  category    String?  @db.VarChar(50)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  assessments EcSkillAssessment[]

  @@map("skills")
}

// ===================================================================
// MODULE 2: SKILL TESTING & CERTIFICATION
// ===================================================================

model EcSkillAssessment {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skill_id        Int
  assessment_name String     @db.VarChar(150)
  description     String?    @db.Text
  difficulty_level SkillLevel @default(intermediate)
  is_active       Boolean    @default(true)
  duration        Int        @default(30)
  passing_score   Int        @default(50)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @default(now()) @updatedAt

  skill           Skill           @relation(fields: [skill_id], references: [id], onDelete: Cascade)
  exam_questions  EcExamQuestion[]
  test_attempts   EcTestAttempt[]
  certificates    EcCertificate[]

  @@unique([skill_id, assessment_name])
  @@map("ec_skill_assessments")
}

model EcQuestion {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_text  String   @db.Text
  question_type  String   @db.VarChar(20) // MCQ, CODING, PRACTICAL
  options        Json?    @db.JsonB
  correct_answer String   @db.Text
  points         Int      @default(1)
  explanation    String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  exam_questions EcExamQuestion[]
  submissions    EcSubmission[]

  @@map("ec_questions")
}

model EcExamQuestion {
  assessment_id Int
  question_id   Int

  assessment    EcSkillAssessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  question      EcQuestion       @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@id([assessment_id, question_id])
  @@map("ec_exam_questions")
}

model EcTestAttempt {
  id                 Int       @id @default(autoincrement())
  uuid               String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            Int
  assessment_id      Int
  score              Int?      @default(0)
  total_points       Int?      @default(0)
  percentage_score   Decimal?  @db.Decimal(5, 2)
  status             String?   @default("in_progress") @db.VarChar(20) // in_progress, passed, failed, expired
  started_at         DateTime? @default(now())
  completed_at       DateTime?
  time_taken_seconds Int?

  user               User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assessment         EcSkillAssessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  submissions        EcSubmission[]
  certificate        EcCertificate?

  @@map("ec_test_attempts")
}

model EcSubmission {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attempt_id     Int
  question_id    Int
  given_answer   String   @db.Text
  is_correct     Boolean  @default(false)
  points_earned  Int      @default(0)
  auto_graded    Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  attempt        EcTestAttempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question       EcQuestion    @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([attempt_id, question_id])
  @@map("ec_submissions")
}

model EcCertificate {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            Int
  assessment_id      Int
  attempt_id         Int      @unique
  certificate_number String   @unique @db.VarChar(100)
  certificate_url    String?  @db.VarChar(500)
  issue_date         DateTime @default(now())
  expiry_date        DateTime? @db.Date
  is_verified        Boolean  @default(true)

  user               User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assessment         EcSkillAssessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  attempt            EcTestAttempt     @relation(fields: [attempt_id], references: [id], onDelete: Cascade)

  @@unique([user_id, assessment_id])
  @@map("ec_certificates")
}

model EcBadge {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   Int
  name      String   @db.VarChar(100)
  criteria  String   @db.Text
  issueDate DateTime @default(now())

  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("ec_badges")
}
