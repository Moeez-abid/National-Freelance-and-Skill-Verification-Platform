# ─────────────────────────────────────────────────────────────────────────────
# Module 3 – Project & Gig Marketplace — Environment Variables Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Local PostgreSQL Connection ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nfasvp_module3
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Server
PORT=4003
NODE_ENV=development

# Module 1 (Auth) — JWT public key or secret for token verification
MODULE1_JWT_SECRET=your-jwt-secret-from-module1
MODULE1_BASE_URL=http://localhost:4001

# Module 6 (Communication) — Outbound integration
MODULE6_BASE_URL=http://localhost:4006
MODULE6_API_KEY=module6-internal-api-key

# Module 7 (Payment & Escrow) — Outbound integration
MODULE7_BASE_URL=http://localhost:4007
MODULE7_API_KEY=module7-internal-api-key

# Module 4 (AI Matching) — Inbound integration auth
MODULE4_API_KEY=module4-internal-api-key

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
