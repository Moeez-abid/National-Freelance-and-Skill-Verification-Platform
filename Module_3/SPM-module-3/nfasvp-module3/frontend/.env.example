# ─────────────────────────────────────────────────────────────────────────────
# Module 3 — Frontend Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────

# Dev JWT secret — MUST match MODULE1_JWT_SECRET in backend/.env
# Used by devAuth.js to generate tokens for local development/testing.
VITE_DEV_JWT_SECRET=your_super_secret_jwt_key_here

# Backend API base URL (reference only — actual calls go through Vite proxy)
VITE_API_BASE_URL=http://localhost:4003/api/v1
