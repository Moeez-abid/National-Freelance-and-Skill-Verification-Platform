		{
			"name": "Wallets",
			"item": [
				{
					"name": "Get Wallet by User ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "x-user-id",
								"value": "{{userId}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/wallets/user/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["wallets", "user", "{{userId}}"]
						},
						"description": "Retrieve wallet for a specific user. Requires OwnershipGuard (x-user-id header)."
					},
					"response": [
						{
							"name": "200 — Wallet Found",
							"status": "OK",
							"code": 200,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n  \"id\": 1,\n  \"user_id\": 1,\n  \"currency_code\": \"USD\",\n  \"available_balance\": \"5000.0000\",\n  \"held_balance\": \"1200.0000\",\n  \"reserved_balance\": \"0.0000\",\n  \"wallet_status\": \"active\",\n  \"created_at\": \"2025-01-15T10:00:00.000Z\",\n  \"updated_at\": \"2025-01-15T10:00:00.000Z\"\n}"
						},
						{
							"name": "404 — Wallet Not Found",
							"status": "Not Found",
							"code": 404,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n  \"statusCode\": 404,\n  \"message\": \"Wallet not found for user 999\"\n}"
						}
					]
				},
