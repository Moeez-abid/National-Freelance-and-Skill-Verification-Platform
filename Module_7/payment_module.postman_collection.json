						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "x-user-id",
								"value": "{{userId}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": 1,\n  \"amount\": 500\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/wallets/fund",
							"host": ["{{baseUrl}}"],
							"path": ["wallets", "fund"]
						},
						"description": "Add funds to a user's wallet. Requires OwnershipGuard."
