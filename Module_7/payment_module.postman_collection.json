					"response": [
						{
							"name": "200 — Wallet Funded",
							"status": "OK",
							"code": 200,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n  \"id\": 1,\n  \"user_id\": 1,\n  \"currency_code\": \"USD\",\n  \"available_balance\": \"5500.0000\",\n  \"held_balance\": \"1200.0000\",\n  \"reserved_balance\": \"0.0000\",\n  \"wallet_status\": \"active\",\n  \"created_at\": \"2025-01-15T10:00:00.000Z\",\n  \"updated_at\": \"2025-01-15T12:30:00.000Z\"\n}"
